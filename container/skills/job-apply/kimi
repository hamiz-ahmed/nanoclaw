#!/usr/bin/env node
'use strict';

/**
 * kimi — call Kimi (Moonshot AI) API with a prompt from stdin.
 *
 * Usage:
 *   echo "prompt text" | kimi
 *   kimi < prompt.txt
 *
 * Reads KIMI_API_KEY from env or /workspace/project/.env
 * Outputs the model's response text to stdout.
 */

const https = require('https');
const fs = require('fs');

// Read API key from env or .env file
let apiKey = process.env.KIMI_API_KEY || '';
if (!apiKey) {
  try {
    const env = fs.readFileSync('/workspace/project/.env', 'utf-8');
    const match = env.match(/^KIMI_API_KEY=(.+)$/m);
    if (match) apiKey = match[1].trim().replace(/^["']|["']$/g, '');
  } catch {}
}
if (!apiKey) {
  process.stderr.write('Error: KIMI_API_KEY not found in env or /workspace/project/.env\n');
  process.exit(1);
}

// Read full prompt from stdin
let prompt = '';
process.stdin.setEncoding('utf-8');
process.stdin.on('data', chunk => { prompt += chunk; });
process.stdin.on('end', () => {
  const payload = JSON.stringify({
    model: 'kimi-k2.5',
    messages: [{ role: 'user', content: prompt }],
    temperature: 0.7,
  });

  const options = {
    hostname: 'api.moonshot.cn',
    path: '/v1/chat/completions',
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`,
      'Content-Length': Buffer.byteLength(payload),
    },
  };

  const req = https.request(options, (res) => {
    let body = '';
    res.on('data', chunk => { body += chunk; });
    res.on('end', () => {
      try {
        const json = JSON.parse(body);
        if (json.error) {
          process.stderr.write(`Kimi API error: ${json.error.message}\n`);
          process.exit(1);
        }
        const content = json.choices?.[0]?.message?.content;
        if (!content) {
          process.stderr.write(`Unexpected response: ${body}\n`);
          process.exit(1);
        }
        process.stdout.write(content);
      } catch (e) {
        process.stderr.write(`Failed to parse response: ${body}\n`);
        process.exit(1);
      }
    });
  });

  req.on('error', (e) => {
    process.stderr.write(`Request failed: ${e.message}\n`);
    process.exit(1);
  });

  req.write(payload);
  req.end();
});
