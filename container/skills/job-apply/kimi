#!/usr/bin/env node
import https from 'https';
import fs from 'fs';

/**
 * kimi — call Kimi K2.5 API with a prompt from stdin.
 * Usage: echo "prompt" | kimi   OR   kimi < prompt.txt
 */

// Read API key from env or /workspace/project/.env
let apiKey = process.env.KIMI_API_KEY || '';
if (!apiKey) {
  try {
    const env = fs.readFileSync('/workspace/project/.env', 'utf-8');
    const match = env.match(/^KIMI_API_KEY=(.+)$/m);
    if (match) apiKey = match[1].trim().replace(/^["']|["']$/g, '');
  } catch {}
}
if (!apiKey) {
  process.stderr.write('Error: KIMI_API_KEY not found\n');
  process.exit(1);
}

// Read full prompt from stdin
let prompt = '';
process.stdin.setEncoding('utf-8');
process.stdin.on('data', chunk => { prompt += chunk; });
process.stdin.on('end', () => {
  const payload = JSON.stringify({
    model: 'kimi-k2.5',
    messages: [{ role: 'user', content: prompt }],
    temperature: 1,
  });

  const req = https.request({
    hostname: 'api.moonshot.ai',
    path: '/v1/chat/completions',
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`,
      'Content-Length': Buffer.byteLength(payload),
    },
  }, (res) => {
    let body = '';
    res.on('data', chunk => { body += chunk; });
    res.on('end', () => {
      try {
        const json = JSON.parse(body);
        if (json.error) {
          process.stderr.write(`Kimi API error: ${json.error.message}\n`);
          process.exit(1);
        }
        const content = json.choices?.[0]?.message?.content;
        if (!content) {
          process.stderr.write(`Unexpected response: ${body}\n`);
          process.exit(1);
        }
        process.stdout.write(content);
      } catch (e) {
        process.stderr.write(`Failed to parse response: ${body}\n`);
        process.exit(1);
      }
    });
  });

  req.on('error', (e) => {
    process.stderr.write(`Request failed: ${e.message}\n`);
    process.exit(1);
  });
  req.write(payload);
  req.end();
});
